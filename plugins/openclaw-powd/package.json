{
  "name": "@starcoinorg/openclaw-powd",
  "version": "1.0.0-rc.2",
  "description": "powd gives OpenClaw a local mining capability that an agent can use through natural language.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/starcoinorg/powd/tree/master/plugins/openclaw-powd",
  "bugs": {
    "url": "https://github.com/starcoinorg/powd/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starcoinorg/powd.git",
    "directory": "plugins/openclaw-powd"
  },
  "type": "module",
  "files": [
    "index.js",
    "src/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --test ./test/*.test.js"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.8"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "install": {
      "npmSpec": "@starcoinorg/openclaw-powd",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.8"
    },
    "compat": {
      "pluginApi": ">=2026.4.8"
    },
    "build": {
      "openclawVersion": "2026.4.8",
      "pluginSdkVersion": "2026.4.8"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
